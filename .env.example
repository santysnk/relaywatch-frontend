# Plantilla de variables de entorno del frontend.
#
# Cómo usarlo:
# 1. Copiá este archivo a `.env` (en la misma carpeta frontend/).
# 2. Ajustá la URL si tu backend no corre en el puerto 3000.
# 3. NO subas el `.env` al repo (ya está en .gitignore).

# URL base de la API (el backend NestJS)
VITE_API_URL=http://localhost:3000
